meta:
  title: Code Analysis Server Filesystem Instructions
  version: '1.0'
  locale: en
  status: active
  source: MCP help inspected for fs_remove, fs_move, fs_copy, create_text_file, 
    delete_file, delete_files_by_mask, list_deleted_files, 
    restore_deleted_files, cleanup_deleted_files, and backup commands
overview:
  purpose: 'Filesystem-level file operations on a registered project served by code-analysis-server:
    create, move, copy, remove, recycle-bin (soft delete), and backup. Complements
    the universal edit-session standard (structured in-file edits) and the search
    standard.'
  scope: Whole-file lifecycle. For in-file structured edits use the universal 
    edit-session workflow; for content search use the search standard.
  key_constraint: create_text_file accepts plain-text suffixes only 
    (.md/.txt/.rst/.adoc). JSON/YAML/Python files MUST be created and edited 
    through the universal edit-session workflow (universal_file_open 
    create=true, edit, write); create_text_file rejects them with 
    YAML_CREATE_USE_UNIVERSAL_FILE_SAVE / JSON_CREATE_USE_UNIVERSAL_FILE_SAVE.
path_rules:
  relative: All file_path values are project-relative POSIX paths; never pass 
    host filesystem absolute paths.
  no_traversal: No .. traversal; paths resolve under project root only.
  forbidden_targets:
  - project-local .venv / venv
  - site-packages
  - installed packages
  project_id: Resolve via list_projects; LMRS project_id is fixed in the system 
    prompt.
create_commands:
  create_text_file:
    purpose: Create a plain-text file (.md/.txt/.rst/.adoc only).
    required_params:
    - project_id
    - file_path
    optional_params:
      content: initial text, default empty
      create_dirs: default true
      overwrite: default false
      encoding: default utf-8
      backup: default true; snapshot before overwrite
    rejects: JSON/YAML/Python suffixes -> use universal edit-session workflow
  structured_create:
    purpose: Create JSON/YAML/Python files.
    method: universal_file_open with create=true and initial_content, then 
      universal_file_edit, then universal_file_write (preview then commit).
    note: This is the ONLY supported path for YAML/JSON/Python creation.
move_copy:
  fs_move:
    purpose: Move/rename a file within the project (mv).
    required_params:
    - project_id
    - source_path
    - dest_path
    optional_params:
      overwrite: default false
      backup: default true
    note: Backs up source (and destination when overwriting). Does not update DB
      file rows; run update_indexes or rely on the watcher.
  fs_copy:
    purpose: Copy a file within the project (cp).
    note: Uses version history (backup before overwrite); does not update the 
      code index.
delete_commands:
  fs_remove:
    purpose: Hard rm of a single file under project root.
    required_params:
    - project_id
    - file_path
    optional_params:
      backup: default true; backup to old_code before unlink
    note: Does not touch DB rows; use repair_database / update_indexes as 
      needed. Works without trash_dir configured.
    use_when: Removing a file outright (e.g. an accidental or empty file) when 
      recycle-bin semantics are not required or trash_dir is unavailable.
  delete_file:
    purpose: Soft-delete to recycle bin.
    required_params:
    - project_id
    - file_path
    requires: code_analysis.storage.trash_dir configured; otherwise returns 
      DELETE_FILE_CONFIG_ERROR / DELETE_FAILED.
    recovery: unmark_deleted_file
    note: Moves bytes to trash_dir and marks deleted in DB; not a secure wipe.
  delete_files_by_mask:
    purpose: Bulk soft-delete of DB-tracked files matching a path mask (prefix, 
      rm-like globs, **/).
    note: Leading / is project root, not host /.
recycle_bin:
  list_deleted_files: List soft-deleted files (trash path, original_path); 
    optional file_pattern/glob.
  unmark_deleted_file: Restore a single file from the version/trash flow.
  restore_deleted_files: Restore multiple deleted files; cancelled if any target
    path already exists.
  cleanup_deleted_files: Purge soft-deleted file rows; with hard_delete=true 
    permanently removes bytes + DB (empty the file recycle bin).
backup_commands:
  list_backup_files: List backed-up files in old_code; optional 
    file_pattern/glob.
  list_backup_versions: List backup versions for one literal file path.
  restore_backup_file: Restore a file from backup.
  delete_backup: Delete one backup from history.
  collapse_versions: Collapse versions, keeping only the latest.
  clear_all_backups: Clear all backups and history.
error_handling:
  rule: 'On any command error or unexpected result, stop and inspect: read the returned
    error code/message, consult help(cmdname=...) for the exact schema, then choose
    the next safe command. Do not blind-retry sibling commands or invent parameters.'
  common_errors:
    DELETE_FAILED / DELETE_FILE_CONFIG_ERROR: trash_dir not configured -> use 
      fs_remove for outright removal, or configure trash_dir.
    YAML_CREATE_USE_UNIVERSAL_FILE_SAVE: Do not use create_text_file for YAML ->
      use universal edit-session workflow.
    SERVER_NOT_FOUND for a command: The command does not exist on this server ->
      re-list via help (no params) and pick an existing command.
    FILE_NOT_FOUND: Confirm the project-relative path with list_project_files.
    unknown parameter: Call help(cmdname=...) and pass only schema-defined 
      parameters.
verification_policy:
  required:
  - Verify every create/move/remove with a separate read (list_project_files or 
    universal_file_preview).
  - Queue completed is not success; for queued work inspect 
    result.command.result.success.
  forbidden:
  - Do not edit .venv, site-packages, or installed packages.
  - Do not run destructive commands without explicit project-relative target 
    validation.
artifact_location:
  path: docs/standards/code_analysis_fs_instructions.yaml
  rationale: Stored with the other standards in docs/standards.
